# ============================================================
# config.yaml — Configuração do Hermes Agent
# ============================================================
# COPIE PARA: ~/.hermes/config.yaml
# ============================================================

model:
  default: MiniMax-M2.7
  provider: minimax
  base_url: https://api.minimax.io/anthropic

providers: {}
fallback_providers: []

toolsets:
  - hermes-cli

agent:
  max_turns: 90
  gateway_timeout: 1800
  tool_use_enforcement: auto
  gateway_timeout_warning: 900

terminal:
  backend: local
  modal_mode: auto
  timeout: 180

display:
  compact: false
  personality: technical

approvals:
  mode: manual
  timeout: 60

logging:
  level: INFO
  max_size_mb: 5
  backup_count: 3

_config_version: 13
