# ============================================
# Cindy Orchestrator - Environment Variables
# ============================================
# COPIE ESTE ARQUIVO PARA .scr/.env E PREENCHA OS VALORES

# ============================================
# 1. TELEGRAM - Obrigatório
# ============================================
# Obtenha de: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=SEU_TELEGRAM_BOT_TOKEN_AQUI

# ============================================
# 2. N8N API Key - Obrigatório
# ============================================
# Configure no n8n (http://localhost:5678) > Settings > API
N8N_API_KEY=SUA_N8N_API_KEY_AQUI

# ============================================
# 3. N8N Encryption Key - Gere 32+ chars
# ============================================
# Gere em: https://passwordsgenerator.net/
N8N_ENCRYPTION_KEY=GERE_SUA_CHAVE_DE_32_CARACTERES_AQUI

# ============================================
# URLs e Configurações
# ============================================
N8N_URL=http://n8n-local:5678
N8N_WEBHOOK_PATH=cindy-telegram

# ============================================
# Logging (opcional)
# ============================================
LOG_LEVEL=info
N8N_LOG_LEVEL=info
