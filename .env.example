# ============================================================
# CINDY-OC - Template de Configuracao de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env com valores reais.
# ============================================================

# === CREDENCIAIS HETZNER (Producao) ===
# Solicite ao admin/PO
HETZNER_API_TOKEN=your_hetzner_api_token_here

# === CREDENCIAIS RAILWAY ===
# Solicite ao admin/PO ou pegue no dashboard Railway
RAILWAY_API_TOKEN=your_railway_api_token_here

# === CREDENCIAIS N8N ===
# Gere uma nova chave de criptografia (32+ caracteres aleatorios)
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# === CREDENCIAIS MINIMAX (API AI) ===
# Solicite ao admin/PO
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimax.io/anthropic/v1/messages

# === POSTGRES (Configuracao Railway) ===
# Opcional - Railway fornece DATABASE_URL automaticamente
POSTGRES_HOST=your_postgres_host_here
POSTGRES_PORT=5432
POSTGRES_DATABASE=your_database_name_here
POSTGRES_USER=your_database_user_here
POSTGRES_PASSWORD=your_database_password_here
